{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "dist",
    "outDir": "dist",
    "rootDir": "rn",
    "baseUrl": ".",
    "paths": {
      "react-native": [
        "./node_modules/@types/react-native"
      ]
    }
  },
  "include": [
    "rn/**/*.ts",
    "rn/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "preview"
  ],
  "extends": "expo/tsconfig.base"
}
