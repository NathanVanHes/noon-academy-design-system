{
  "name": "@noon/design-system",
  "version": "0.1.0",
  "description": "Noon Academy — Proven Routes design system for React Native",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.mjs",
      "require": "./dist/tokens.js"
    }
  },
  "files": [
    "dist",
    "rn"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "explorer": "cd preview && npx expo start"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-safe-area-context": ">=4",
    "react-native-svg": ">=13"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-native": "^0.72.8",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-svg": "^15.15.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "license": "UNLICENSED",
  "private": true
}
